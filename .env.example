# VendorVault — environment variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.

# Server
PORT=5000
DEBUG=false

# WhatsApp Business API (Meta Developer Portal)
# Get these from https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
