# VendorVault — environment variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.

# Server
PORT=5000
DEBUG=false

# Where the SQLite database is written. On Railway, mount a Volume here so
# your data survives redeploys. Locally you can leave this unset.
DB_DIR=/app/data

# Owner login. Change these before deploying anywhere public.
# APP_SECRET_KEY signs the session cookie — set it to a long random string.
APP_USERNAME=owner
APP_PASSWORD=change-this-password
APP_SECRET_KEY=set-a-long-random-string-here

# WhatsApp Business API (Meta Developer Portal)
# Get these from https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
